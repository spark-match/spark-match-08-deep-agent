# =============================================================================
# Spark Match Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# --- Environment ---
# Options: local | agentcore
SPARK_ENVIRONMENT=local

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL
SPARK_LOG_LEVEL=INFO

# --- Model Configuration ---
# Provider: bedrock | openai | anthropic | ollama
SPARK_MODEL_PROVIDER=bedrock
# Model ID (depends on provider)
SPARK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514
# AWS Region for Bedrock
SPARK_AWS_REGION=us-east-1

# --- AWS Credentials ---
# If using Bedrock, ensure AWS credentials are configured via:
# - AWS CLI (aws configure)
# - Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
# - IAM Role (if running on AWS infrastructure)

# --- API Server ---
SPARK_API_HOST=0.0.0.0
SPARK_API_PORT=8000
# Comma-separated list of allowed origins (Angular dev server)
SPARK_CORS_ORIGINS=["http://localhost:4200"]

# --- Agent limits ---
# Max LLM turns per session (LangGraph MessagesState length cap)
SPARK_MAX_TURNS=50
# Max web_search tool calls per session (prevents Tavily quota burn)
# Set to 0 to disable the cap
SPARK_MAX_WEB_SEARCHES_PER_SESSION=6

# --- Observability (optional) ---
# SPARK_LANGSMITH_API_KEY=your-langsmith-api-key
# SPARK_LANGSMITH_PROJECT=spark-match-agent
# SPARK_LANGSMITH_TRACING=true

# --- Web Search ---
# Tavily (primary): Get free API key at https://tavily.com (1,000 searches/month free)
# SPARK_TAVILY_API_KEY=tvly-your-api-key-here
# DuckDuckGo (fallback): No API key needed, works automatically
